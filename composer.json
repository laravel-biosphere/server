{
    "name": "laravel-biosphere/server",
    "description": "The best bidirectional event exchanging for Laravel it truly deserves, periodt!",
    "type": "library",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "Anafro\\Biosphere\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "authors": [
        {
            "name": "Anatoly Frolov (anafro)",
            "email": "anatolyfroloff@gmail.com"
        }
    ],
    "minimum-stability": "stable",
    "prefer-stable": true,
    "require-dev": {
        "laravel/pint": "^1.29",
        "pestphp/pest": "^4.4",
        "orchestra/testbench": "^11.0"
    },
    "config": {
        "sort-packages": true,
        "preferred-install": "dist",
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "scripts": {},
    "require": {
        "elephantio/elephant.io": "^5.3",
        "illuminate/console": "*"
    },
    "extra": {
        "laravel": {
            "providers": [
                "Anafro\\Biosphere\\Providers\\BiosphereServiceProvider"
            ]
        }
    }
}
